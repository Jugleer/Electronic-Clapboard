// Wi-Fi credentials template.
//
// Copy this file to `secrets.h` (which is gitignored) and fill in your
// values. The firmware build expects these symbols to be defined before
// it can connect to your network.
//
// v1 keeps creds in a header on purpose: simple, no NVS provisioning,
// no captive portal. v2 will move this to runtime config.

#pragma once

#define WIFI_SSID     "your-network-ssid"
#define WIFI_PASSWORD "your-network-password"

// mDNS hostname the firmware advertises. Default `clapboard` resolves as
// `clapboard.local` on macOS / Linux / Windows-with-Bonjour. Change if you
// want multiple devices on one LAN.
#define MDNS_HOSTNAME "clapboard"
