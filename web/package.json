{
  "name": "electronic-clapboard-editor",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Browser-based editor that rasterises a slate layout and POSTs it to the Electronic Clapboard firmware. Skeleton only at Phase 0.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "konva": "10.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-konva": "18.2.14",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@napi-rs/canvas": "0.1.100",
    "@types/node": "20.17.6",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "8.15.0",
    "@typescript-eslint/parser": "8.15.0",
    "@vitejs/plugin-react": "4.3.3",
    "eslint": "8.57.1",
    "eslint-plugin-react-hooks": "4.6.2",
    "eslint-plugin-react-refresh": "0.4.14",
    "jsdom": "25.0.1",
    "prettier": "3.3.3",
    "typescript": "5.6.3",
    "vite": "5.4.11",
    "vitest": "2.1.5"
  }
}
