# PlatformIO
.pio/
.pioenvs/
.piolibdeps/
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch/

# Build artefacts
*.o
*.obj
*.elf
*.bin
*.hex
*.map

# Cross-language and canvas-glue oracle fixtures are checked-in on purpose
# (negates *.bin above). oracle_frame.bin (Phase 0) pins the wire format;
# clapper_hero.bin (Phase 3) pins the RGBA → threshold → pack glue;
# icon_movie_64.bin (Phase 5) pins the icon-rasteriser output for the
# canonical clapboard icon at 64×64 — the visual-regression snapshot;
# fs_oracle_gradient.bin (Phase 6) pins our Floyd-Steinberg port to PIL
# byte-for-byte on a 64×32 ramp+diagonal pattern.
!web/src/__fixtures__/oracle_frame.bin
!web/src/__fixtures__/clapper_hero.bin
!web/src/__fixtures__/icon_movie_64.bin
!web/src/__fixtures__/fs_oracle_gradient.bin

# Tabler SVG download cache for tools/rasterise_icons.py — committed
# PNG masters in web/public/icons/ are the build output.
tools/icons-cache/

# IDE / OS cruft
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Local overrides (COM ports, secrets, etc.)
platformio_override.ini
secrets.h
.env

# Python virtual environment (PlatformIO Core installed here)
.venv/
venv/

# Generated by tools/generate_slides.py (regenerate locally with python tools/generate_slides.py)
include/slides_artwork.h
tools/preview/

# Python tooling caches
__pycache__/
*.pyc
.pytest_cache/

# Web frontend (per-dir .gitignore handles dist/node_modules; this is belt-and-braces)
web/node_modules/
web/dist/
web/coverage/

# Personal screensaver scans — copyrighted material the user owns but
# shouldn't redistribute via the repo (e.g. M.C. Escher prints, in
# copyright until ~2042). Use the `personal-*` prefix to keep them local.
web/src/assets/screensaver/personal-*

# Claude Code — user-local settings (commands/ is shared)
.claude/settings.local.json

# CMake leftovers if anyone opens with Arduino IDE
build/
CMakeCache.txt
CMakeFiles/
